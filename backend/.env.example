## Example environment variables for Task Management backend
# Copy this file to .env and fill values for local development or production

# Example environment variables for Task Management backend
# Copy this file to .env and fill values for local development or production

# MongoDB connection string. This is required for direct MongoDB storage.
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mydb?retryWrites=true&w=majority

# JWT secret used to sign tokens
JWT_SECRET=your_strong_jwt_secret

# Port to run the backend on
PORT=4000

# Node Environment (development, production, test)
NODE_ENV=development
